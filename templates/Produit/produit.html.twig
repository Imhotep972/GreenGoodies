{% extends 'base.html.twig' %}

{% block title %}Produit{% endblock %}
{% block body %}
			<div class="container-fluid p-0 m-0">

				<!-- Début section PRODUIT -->
				<section class="gg-product" style="background:#FFFDF7;">
					<div class="container-fluid p-0 m-0">
						<article>
							<div class="row">
								<div class="col-12 col-lg-7 m-0 p-0 d-flex" style="max-width:734px;">
									<!--<div class="d-flex">-->
										<img src="{{ asset('images/produits/'~product.photo)}}" class="gg-product-image img-fluid" alt="{{ product.name }}">
									<!--</div>-->
								</div>
								<div class="col-12 col-lg-5 d-flex flex-column p-0 mx-auto mh-100" style="max-width:465px;">
									<div class="container p-0 m-0 mt-5">
										<h2 class="mb-3">{{ product.name}}</h2>
										<p class="price mb-3">{{ product.prix | number_format(2,',',' ') }}€</p>
										<p class="desc mb-3">Description</p>
										{# On structure le texte selon les CRLF -> <p></p>p> #}
										{% for ligne in tabDesc %}
												<p class="my-3">{{ ligne|trim }}</p>
										{% endfor %}
									</div>
									{# si non connecté, on n'afiche pas les= bouton ajouter au panier #}
									{% if is_granted('ROLE_USER') and app.user.archive is empty %}

									<div class="container p-0 m-0 mt-auto">
										<div class="p-0 m-0" >
											<a href="{{ path('app_gg_cart_add',{id: product.id}) }}" class="btn custom-btn custom2-btn mx-auto mb-0" id="ajoutPanier" style="color:#ffffff;border-radius:0;padding:30px 0">Ajouter au panier</a>
										</div>
									</div>
									{% endif %}
								</div>	
							</div>
						</article>
					</div>				
				</section><!-- Fin Section Produit -->
			</div>
{% endblock %}