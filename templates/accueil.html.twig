{% extends 'base.html.twig' %}

{% block title %}Accueil - {{ parent() }}{% endblock %}

{% block header %}
    {% include 'menu/menu_deconnecte.html.twig' %}
{% endblock %}

{% block body %}

			<!-- Début section Hero -->
			<section class="gg-hero">
				<div class="container-fluid h-100">
					<article>
						<div class="row h-100">
							<div class="col-12 col-md-6 d-flex align-items-center justify-content-center">
								<div class="container" style="width:362px;padding-auto;">
									<h1 class="mb-4">Bienvenue</h1>
									<p>Découvrez notre univers de produits durables et éthiques pour une consommation responsable.</p>
									<p>Retrouvez des articles d’hygiène & beauté, des accessoires & boissons et du prêt à porter</p>
								</div>
							</div>
							<div class="col12 col-md-6 p-0 m-0">
								<img src="images/mask group.png" alt="" height="751" class="w-100 image-fluid"/>
							</div>	
						</div>
					</article>
				</div>
			</section><!-- Fin Section HERO -->
			
			<section class="nosProduits">
				<div class="text-start" style="padding:30px 100px;height:81px;width:100%;background:#FFFDF7">
					<h3>Nos produits </h3>
				</div>
			</section>
			
			<!-- Début section PRODUITS -->
			<section class="gg-produits" style="background-color:#FFFDF7;">
				<div class="container-fluid p-0 m-0">

					<div class="row p-0 m-0" style="background-color:#FFFDF7;">
						<div class="col-12 col-md-6 col-lg-4 p-0 m-0">
							<div class="card">
								<!-- image produit -->
								<img src="{{ asset('images/Rectangle 4.png') }}" class="card-img-top" alt="Photo produit">
								<div class="card-body d-flex flex-column">
									<!-- div Titre / Description - Prix - Bouton "Voir le produit" -->
									<div class="desc">
										<h4 class="card-title">Kit d'hygiène recyclable </h4>
										<p class="card-text">FPour une salle de bain éco-friendly</p>
									</div>
									<!-- Prix -->
									<h4 class="card-title">24,99€</h4>
									<!-- bouton "voir le produit" placer en bas de la zone -->
									<div class="d-flex mt-auto align-items-end p-0">
										<a href="#" class="btn custom3-btn " role="button" style="">Voir le produit</a>
									</div>
								</div>
							</div>		
						</div>

						<div class="col-12 col-md-6 col-lg-4 p-0 m-0"> <!-- style="height:692px;background-color:#FFFDF7;"> -->
